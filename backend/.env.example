# Local SQLite: ilk çalıştırmada tablolar için true (prod'da göçleri ayrı adımda tercih edin)
RUN_MIGRATIONS_ON_STARTUP=true
# Tablolar zaten varsa (eskiden uvicorn/create_all ise) ilk `alembic upgrade head` CREATE TABLE yapmadan
# sürüm işaretini yazar — genelde alembic stamp gerekmez. Bozuk/uyumsuz DB için elle: alembic stamp e51c8113685a

# Local dev (no Postgres): SQLite
DATABASE_URL=sqlite+aiosqlite:///./temizsepet.db
# If you have Postgres running locally:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/temizsepet
JWT_SECRET=change-me
JWT_ALG=HS256
JWT_ACCESS_TOKEN_EXPIRES_MIN=10080

R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=change-me
R2_SECRET_ACCESS_KEY=change-me
R2_BUCKET=temizsepet-missing-products
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
